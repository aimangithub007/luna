#!/bin/bash
# ./stop — Stop all dashboard processes

echo "🛑 Stopping dashboard..."

pkill -f "uvicorn server:app" 2>/dev/null && echo "   ✅ Backend stopped" || echo "   ℹ️  Backend not running"
pkill -f "vite"               2>/dev/null && echo "   ✅ Frontend stopped" || echo "   ℹ️  Frontend not running"

echo "Done."
