# Luna - Hermes Dashboard — Environment Variables
# File ini khusus untuk dashboard custom kita
# Tidak ada perubahan di file Hermes asli

# Token autentikasi dashboard (digunakan sebagai session token internal)
HERMES_DASHBOARD_TOKEN=your_dashboard_token_here

# Login credentials untuk halaman login dashboard kita
DASHBOARD_USERNAME=your_username
DASHBOARD_PASSWORD=your_password_here

# Port backend (opsional, default: 8119)
# BACKEND_PORT=8119

# Port frontend dashboard (default: 5173)
DASHBOARD_PORT=5173

# 9Router API — default port 20128
ROUTER9_URL=http://localhost:20128
VITE_ROUTER9_URL=http://localhost:20128
